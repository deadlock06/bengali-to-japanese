      "note": {
        "en": "For people you haven't seen in a while, not everyday colleagues",
        "bn": "অনেকদিন পরে দেখা হলে বলা হয়, রোজকার সহকর্মীদের নয়",
        "ja": "久しぶりの相手に使う"
      },
      "srs_words": [
        "おげんき",
        "ですか"
      ]
    },
    {
