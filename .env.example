# Bhasago AI proxy — provider keys (tools/web_server.mjs loads this from repo root).
# Copy to `.env` (gitignored) and fill in whichever you have. Blank = that
# provider is skipped; the proxy .filter(p => p.key)s it out of the chain.
# Real shell env vars ALWAYS override this file, so `KEY=... node ...` still works.
#
# The app works fully offline on verified content with NO keys set. Keys only
# power the live AI classroom / sensei replies (online).

# ── FREE / cheap online LLMs (tried FIRST in the "quick" chain, in this order) ──
DEEPSEEK_API_KEY=          # deepseek-chat        — https://platform.deepseek.com
MOONSHOT_API_KEY=          # kimi-latest          — https://platform.moonshot.cn  (or KIMI_API_KEY)
GEMINI_API_KEY=            # gemini-2.5-flash (quick) + gemini-2.5-pro (teach) — https://aistudio.google.com/apikey

# ── OpenAI (fallback in BOTH chains: gpt-4o-mini quick / gpt-4o teach) ──
OPENAI_API_KEY=            # https://platform.openai.com/api-keys

# ── Anthropic (top of the "teach" chain: claude-opus-4-8) ──
ANTHROPIC_API_KEY=         # https://console.anthropic.com/settings/keys
