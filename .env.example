# Bhasago AI proxy — provider keys (tools/web_server.mjs loads this from repo root).
# Copy to `.env` (gitignored) and paste ONE real key after the '='. IMPORTANT:
# put keys on their OWN line with NOTHING after them — an inline "# comment" or
# stray space/em-dash makes the key invalid (the loader now strips '#' and
# rejects non-ASCII, so a bad paste is skipped, not fatal). Blank = provider off.
# The app works fully offline with NO keys — keys only power the live sensei.
# Real shell env vars still override this file (`KEY=... node ...`).

# DeepSeek (quick chain) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Kimi / Moonshot (quick chain) — https://platform.moonshot.cn
MOONSHOT_API_KEY=

# Gemini flash (quick) + pro (teach) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — gpt-4o-mini (quick) / gpt-4o (teach) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — claude-opus-4-8 (top of teach chain) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
