        "ja": "今日（きょう）"
      },
      "note": {
        "en": "Very common time word.",
        "bn": "খুব প্রচলিত সময়-শব্দ।",
        "ja": "よく使う時の言葉。"
      },
      "srs_words": [
        "きょう"
      ]
    },
