        "ja": "半（〜時半）"
      },
      "note": {
        "en": "3:30 = さんじはん (san-ji han).",
        "bn": "৩:৩০ = সানজি হান।",
        "ja": "3時半＝さんじはん。"
      },
      "srs_words": [
        "はん"
      ]
    },
